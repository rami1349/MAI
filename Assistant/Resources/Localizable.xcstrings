    "tos_acceptance" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acceptance of Terms"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aceptación de Términos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "接受条款"
          }
        }
      }
    },
    "tos_acceptance_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By creating an account or using this app, you agree to these Terms of Service. If you are a parent or guardian creating an account for a minor, you accept these terms on their behalf. If you do not agree, please do not use the app."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al crear una cuenta o usar esta aplicación, aceptas estos Términos de Servicio. Si eres padre o tutor creando una cuenta para un menor, aceptas estos términos en su nombre. Si no estás de acuerdo, por favor no uses la aplicación."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过创建账号或使用此应用，你同意这些服务条款。如果你是为未成年人创建账号的父母或监护人，你代表他们接受这些条款。如果你不同意，请不要使用此应用。"
          }
        }
      }
    },
    "tos_ai_disclaimer" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI Features Disclaimer"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descargo de Responsabilidad de IA"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI功能免责声明"
          }
        }
      }
    },
    "tos_ai_disclaimer_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI features (MAI) provide suggestions and analysis only. AI-generated homework reviews, task recommendations, and other outputs may contain errors. Parents and guardians retain full authority over all decisions. AI features are not a substitute for professional educational assessment."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las funciones de IA (MAI) proporcionan solo sugerencias y análisis. Las revisiones de tareas generadas por IA, recomendaciones y otros resultados pueden contener errores. Los padres y tutores conservan plena autoridad sobre todas las decisiones. Las funciones de IA no sustituyen la evaluación educativa profesional."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI功能（MAI）仅提供建议和分析。AI生成的作业审查、任务建议和其他输出可能包含错误。父母和监护人对所有决定保留完全权力。AI功能不能替代专业教育评估。"
          }
        }
      }
    },
    "tos_credits" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI Credits"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Créditos de IA"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI积分"
          }
        }
      }
    },
    "tos_credits_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI credits are consumable purchases that never expire. Credits are used for AI-powered features including chat and homework verification. Credit balances are non-refundable and non-transferable. If your account is deleted, unused credits are forfeited."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los créditos de IA son compras consumibles que nunca expiran. Los créditos se usan para funciones impulsadas por IA, incluyendo chat y verificación de tareas. Los saldos de créditos no son reembolsables ni transferibles. Si tu cuenta se elimina, los créditos no utilizados se pierden."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI积分是不会过期的消耗品购买。积分用于AI驱动的功能，包括聊天和作业验证。积分余额不可退款且不可转让。如果你的账号被删除，未使用的积分将被没收。"
          }
        }
      }
    },
    "tos_limitation_of_liability" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limitation of Liability"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limitación de Responsabilidad"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "责任限制"
          }
        }
      }
    },
    "tos_limitation_of_liability_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app is provided \"as is\" without warranties of any kind. We are not liable for any damages arising from your use of the app, including but not limited to reliance on AI-generated content. Our total liability shall not exceed the amount you paid for the service in the preceding 12 months."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La aplicación se proporciona \"tal cual\" sin garantías de ningún tipo. No somos responsables de daños derivados del uso de la aplicación, incluyendo pero no limitado a la confianza en contenido generado por IA. Nuestra responsabilidad total no excederá el monto pagado por el servicio en los 12 meses anteriores."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用按\"原样\"提供，不提供任何形式的保证。我们不对因使用应用而产生的任何损害承担责任，包括但不限于依赖AI生成的内容。我们的总责任不超过你在前12个月内为服务支付的金额。"
          }
        }
      }
    },
    "tos_subscriptions" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subscriptions & Billing"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suscripciones y Facturación"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "订阅与计费"
          }
        }
      }
    },
    "tos_subscriptions_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium subscriptions are billed through Apple In-App Purchases. Subscriptions auto-renew unless canceled at least 24 hours before the end of the current period. Manage or cancel subscriptions in your Apple ID settings. Prices may vary by region and are subject to change with notice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las suscripciones Premium se facturan a través de Compras dentro de la App de Apple. Las suscripciones se renuevan automáticamente a menos que se cancelen al menos 24 horas antes del final del período actual. Administra o cancela suscripciones en la configuración de tu Apple ID. Los precios pueden variar por región y están sujetos a cambios con aviso previo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium订阅通过Apple应用内购买计费。订阅会自动续订，除非在当前期间结束前至少24小时取消。在你的Apple ID设置中管理或取消订阅。价格可能因地区而异，如有变更将提前通知。"
          }
        }
      }
    },
    "tos_termination" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Account Termination"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terminación de Cuenta"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "账号终止"
          }
        }
      }
    },
    "tos_termination_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You may delete your account at any time through Settings. We may terminate or suspend your account if you violate these terms. Upon termination, your data will be deleted in accordance with our Privacy Policy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes eliminar tu cuenta en cualquier momento a través de Ajustes. Podemos terminar o suspender tu cuenta si violas estos términos. Al terminar, tus datos se eliminarán de acuerdo con nuestra Política de Privacidad."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你可以随时通过设置删除你的账号。如果你违反这些条款，我们可能终止或暂停你的账号。终止后，你的数据将根据我们的隐私政策被删除。"
          }
        }
      }
    },
    "tos_user_conduct" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "User Conduct"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conducta del Usuario"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用户行为"
          }
        }
      }
    },
    "tos_user_conduct_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You agree not to misuse the app, attempt to gain unauthorized access, interfere with other users, or use AI features to generate harmful or inappropriate content. We reserve the right to suspend accounts that violate these terms."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aceptas no hacer mal uso de la aplicación, intentar obtener acceso no autorizado, interferir con otros usuarios o usar funciones de IA para generar contenido dañino o inapropiado. Nos reservamos el derecho de suspender cuentas que violen estos términos."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你同意不滥用应用、不试图获取未授权访问、不干扰其他用户，也不使用AI功能生成有害或不当内容。我们保留暂停违反这些条款的账号的权利。"
          }
        }
      }
    },
