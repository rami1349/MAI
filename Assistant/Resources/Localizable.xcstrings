    "pc_ai_features" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI Features for Minors"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Funciones de IA para Menores"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未成年人的AI功能"
          }
        }
      }
    },
    "pc_ai_features_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI features (MAI) are available to minors only when enabled by a parent. All AI interactions are subject to content safety filters. AI-generated homework reviews are suggestions only — parents make the final decision on approval. Chat history is accessible to family administrators."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las funciones de IA (MAI) están disponibles para menores solo cuando son habilitadas por un padre. Todas las interacciones con IA están sujetas a filtros de seguridad de contenido. Las revisiones de tareas generadas por IA son solo sugerencias — los padres toman la decisión final sobre la aprobación. El historial de chat es accesible para los administradores de la familia."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI功能（MAI）仅在父母启用时对未成年人可用。所有AI互动都受到内容安全过滤器的约束。AI生成的作业审查仅为建议——父母对批准做出最终决定。聊天记录对家庭管理员可见。"
          }
        }
      }
    },
    "pc_contact_us" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contact Us"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contáctanos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "联系我们"
          }
        }
      }
    },
    "pc_contact_us_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you have questions about your child's data or wish to exercise your rights regarding their information, please contact us at support@yourdomain.com. We will respond within 30 days."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tienes preguntas sobre los datos de tu hijo o deseas ejercer tus derechos con respecto a su información, contáctanos en support@yourdomain.com. Responderemos en un plazo de 30 días."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你对孩子的数据有疑问或希望行使关于其信息的权利，请通过 support@yourdomain.com 联系我们。我们将在30天内回复。"
          }
        }
      }
    },
    "pc_data_for_minors" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data Collection for Minors"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recopilación de Datos para Menores"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未成年人数据收集"
          }
        }
      }
    },
    "pc_data_for_minors_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We collect only the minimum data necessary to provide our services to minors: display name, task and habit completion records, homework verification images (temporarily processed, not stored permanently), and AI chat history. We do not collect location data, contacts, or browsing history from any user."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recopilamos solo los datos mínimos necesarios para proporcionar nuestros servicios a menores: nombre para mostrar, registros de tareas y hábitos completados, imágenes de verificación de tareas (procesadas temporalmente, no almacenadas permanentemente) e historial de chat con IA. No recopilamos datos de ubicación, contactos ni historial de navegación de ningún usuario."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们仅收集向未成年人提供服务所需的最少数据：显示名称、任务和习惯完成记录、作业验证图片（临时处理，不永久存储）以及AI聊天记录。我们不收集任何用户的位置数据、联系人或浏览历史。"
          }
        }
      }
    },
    "pc_family_app_notice" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Family App Notice"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aviso de Aplicación Familiar"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "家庭应用通知"
          }
        }
      }
    },
    "pc_family_app_notice_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app is designed for families including children under 13. A parent or guardian must create the family account and invite minor members. By adding a minor to your family, you consent to the collection and processing of their data as described in our Privacy Policy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta aplicación está diseñada para familias incluyendo niños menores de 13 años. Un padre o tutor debe crear la cuenta familiar e invitar a los miembros menores. Al agregar un menor a tu familia, consientes la recopilación y procesamiento de sus datos como se describe en nuestra Política de Privacidad."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用专为包括13岁以下儿童在内的家庭设计。父母或监护人必须创建家庭账号并邀请未成年成员。通过将未成年人添加到你的家庭，你同意按照我们的隐私政策收集和处理他们的数据。"
          }
        }
      }
    },
    "pc_minor_accounts" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minor Accounts"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuentas de Menores"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未成年人账号"
          }
        }
      }
    },
    "pc_minor_accounts_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minor accounts have limited capabilities controlled by the parent/guardian. Parents can configure what features each child can access through the Permissions screen, including task creation, reward management, and AI chat access."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las cuentas de menores tienen capacidades limitadas controladas por el padre/tutor. Los padres pueden configurar qué funciones puede acceder cada niño a través de la pantalla de Permisos, incluyendo creación de tareas, gestión de recompensas y acceso al chat de IA."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未成年人账号具有由父母/监护人控制的有限功能。父母可以通过权限页面配置每个孩子可以访问的功能，包括任务创建、奖励管理和AI聊天访问。"
          }
        }
      }
    },
    "pc_parent_controls" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parent Controls"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controles Parentales"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "家长控制"
          }
        }
      }
    },
    "pc_parent_controls_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parents have full visibility and control over their children's activity. This includes viewing task completions, approving or rejecting homework submissions, managing reward payouts, and reviewing AI chat interactions. Parents can modify or delete their child's data at any time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los padres tienen total visibilidad y control sobre la actividad de sus hijos. Esto incluye ver tareas completadas, aprobar o rechazar envíos de tareas, administrar pagos de recompensas y revisar las interacciones de chat con IA. Los padres pueden modificar o eliminar los datos de sus hijos en cualquier momento."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "父母对其子女的活动拥有完全的可见性和控制权。这包括查看任务完成情况、批准或拒绝作业提交、管理奖励支付以及审查AI聊天互动。父母可以随时修改或删除其子女的数据。"
          }
        }
      }
    },
