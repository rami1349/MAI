    "pp_changes_to_policy" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Changes to This Policy"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambios en esta Política"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "政策变更"
          }
        }
      }
    },
    "pp_changes_to_policy_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We may update this Privacy Policy from time to time. We will notify you of any material changes by posting a notice in the app. Your continued use of the app after changes constitutes acceptance of the updated policy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podemos actualizar esta Política de Privacidad de vez en cuando. Te notificaremos sobre cualquier cambio importante publicando un aviso en la aplicación. Tu uso continuado de la aplicación después de los cambios constituye aceptación de la política actualizada."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们可能会不时更新此隐私政策。我们将通过在应用中发布通知来通知你任何重大变更。变更后你继续使用应用即表示接受更新后的政策。"
          }
        }
      }
    },
    "pp_childrens_privacy" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Children's Privacy"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacidad de los Niños"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "儿童隐私"
          }
        }
      }
    },
    "pp_childrens_privacy_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Our app is designed for family use including minors. Child accounts are created and managed by parents/guardians. We collect minimal data from minors (name, task completions, habit logs). Parents can view, modify, or delete their child's data at any time through the Family Members screen. AI chat history for minors is subject to the same retention and deletion policies."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuestra aplicación está diseñada para uso familiar, incluyendo menores. Las cuentas de niños son creadas y administradas por padres/tutores. Recopilamos datos mínimos de menores (nombre, tareas completadas, registros de hábitos). Los padres pueden ver, modificar o eliminar los datos de sus hijos en cualquier momento a través de la pantalla de Miembros de Familia. El historial de chat con IA para menores está sujeto a las mismas políticas de retención y eliminación."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们的应用程序专为家庭使用而设计，包括未成年人。儿童账号由父母/监护人创建和管理。我们从未成年人处收集最少的数据（姓名、任务完成情况、习惯记录）。父母可以随时通过家庭成员页面查看、修改或删除其子女的数据。未成年人的AI聊天记录适用相同的保留和删除政策。"
          }
        }
      }
    },
    "pp_data_storage" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data Storage & Security"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Almacenamiento y Seguridad de Datos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数据存储与安全"
          }
        }
      }
    },
    "pp_data_storage_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your data is stored securely in Google Cloud (Firebase). All data is encrypted in transit (TLS) and at rest. Firestore security rules ensure users can only access their own family data. We retain your data as long as your account is active."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus datos se almacenan de forma segura en Google Cloud (Firebase). Todos los datos están cifrados en tránsito (TLS) y en reposo. Las reglas de seguridad de Firestore garantizan que los usuarios solo puedan acceder a los datos de su propia familia. Conservamos tus datos mientras tu cuenta esté activa."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的数据安全存储在Google Cloud（Firebase）中。所有数据在传输中（TLS）和静态时均已加密。Firestore安全规则确保用户只能访问自己家庭的数据。我们在你的账号活跃期间保留你的数据。"
          }
        }
      }
    },
    "pp_data_we_collect" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data We Collect"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datos que Recopilamos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们收集的数据"
          }
        }
      }
    },
    "pp_data_we_collect_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We collect information you provide when creating your account (name, email, date of birth), family membership data, task and habit records, calendar events, and AI chat interactions. We also collect device identifiers for push notifications and crash reporting."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recopilamos la información que proporcionas al crear tu cuenta (nombre, correo electrónico, fecha de nacimiento), datos de membresía familiar, registros de tareas y hábitos, eventos del calendario e interacciones con el chat de IA. También recopilamos identificadores de dispositivo para notificaciones push e informes de errores."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们收集你在创建账号时提供的信息（姓名、电子邮件、出生日期）、家庭成员数据、任务和习惯记录、日历事件以及AI聊天互动。我们还收集用于推送通知和崩溃报告的设备标识符。"
          }
        }
      }
    },
    "pp_how_we_use_data" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How We Use Your Data"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cómo Usamos tus Datos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们如何使用你的数据"
          }
        }
      }
    },
    "pp_how_we_use_data_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your data is used to provide and improve our family management services, deliver AI-powered homework verification and task assistance, send notifications about tasks and events, process subscription payments, and analyze app performance through anonymized analytics."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus datos se utilizan para proporcionar y mejorar nuestros servicios de gestión familiar, ofrecer verificación de tareas con IA y asistencia, enviar notificaciones sobre tareas y eventos, procesar pagos de suscripción y analizar el rendimiento de la aplicación mediante análisis anónimos."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的数据用于提供和改进我们的家庭管理服务、提供AI驱动的作业验证和任务协助、发送有关任务和事件的通知、处理订阅付款，以及通过匿名分析来分析应用性能。"
          }
        }
      }
    },
    "pp_third_party_services" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Third-Party Services"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Servicios de Terceros"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "第三方服务"
          }
        }
      }
    },
    "pp_third_party_services_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use Firebase (Google) for authentication, database, cloud functions, and crash reporting. AI features are powered by Anthropic Claude. Payments are processed through Apple In-App Purchases. We do not sell your personal data to any third party."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilizamos Firebase (Google) para autenticación, base de datos, funciones en la nube e informes de errores. Las funciones de IA son impulsadas por Anthropic Claude. Los pagos se procesan a través de Compras dentro de la App de Apple. No vendemos tus datos personales a terceros."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们使用Firebase（Google）进行身份验证、数据库、云函数和崩溃报告。AI功能由Anthropic Claude提供支持。付款通过Apple应用内购买处理。我们不会将你的个人数据出售给任何第三方。"
          }
        }
      }
    },
    "pp_your_rights" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Rights"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus Derechos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的权利"
          }
        }
      }
    },
    "pp_your_rights_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have the right to access, correct, or delete your personal data. You can delete your account and all associated data through Settings > Delete Account. Upon deletion, your data is permanently removed from our servers within 30 days."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tienes derecho a acceder, corregir o eliminar tus datos personales. Puedes eliminar tu cuenta y todos los datos asociados a través de Ajustes > Eliminar Cuenta. Al eliminarse, tus datos se eliminan permanentemente de nuestros servidores en un plazo de 30 días."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你有权访问、更正或删除你的个人数据。你可以通过设置 > 删除账号来删除你的账号和所有相关数据。删除后，你的数据将在30天内从我们的服务器中永久删除。"
          }
        }
      }
    },
